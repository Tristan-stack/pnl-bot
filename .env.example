DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# GMGN OpenAPI key (get yours at https://gmgn.ai/ai after uploading your Ed25519 public key)
GMGN_API_KEY=
# Optional: override default GMGN API host (default: https://openapi.gmgn.ai)
# GMGN_HOST=https://openapi.gmgn.ai
# GMGN rate limit is 2 req/s; default is 1000ms between calls (safer on shared IPs e.g. Railway)
# GMGN_MIN_REQUEST_INTERVAL_MS=1000
# Max 429 retries per page before moving on (default 8)
# GMGN_MAX_429_RETRIES_PER_PAGE=8
# GMGN_DEBUG_LOG=0
DATABASE_URL=file:./dev.db
POLL_INTERVAL_SECONDS=30
DATA_DIR=./data
PNL_DEBUG_LOG=0
# IANA timezone for /pnl today & wallet "today" window (default Europe/Paris)
PNL_DAYTIMEZONE=Europe/Paris
# Optional: force SOL/USD for PnL cards (otherwise GMGN /v1/token/info, then CoinGecko; cache 60s; fallback ~140)
# SOL_PRICE_USD=145
